    "kind": "classify",
    "table": "flat",
    "column": "assignee_names"
   },
   {
    "kind": "transfer_type",
    "table": "flat",
    "assignor_type": "company",
    "assignee_type": "company"
   },
   {
    "kind": "derive",
    "table": "flat",
    "source": "transaction_date",
    "op": "year"
   },
