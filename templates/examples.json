 {
  "name": "Top assignees by patent count",
  "load": {
   "limit": null
  },
  "steps": [
   {
    "kind": "normalize",
    "table": "flat",
    "column": "assignee_names"
   },
   {
    "kind": "filter",
    "table": "flat",
    "clauses": [
     {
      "column": "doc_kind",
      "op": "starts_with",
      "value": "B",
      "value2": "",
      "case_sensitive": false
     }
    ],
    "combine": "and"
   },
   {
    "kind": "aggregate",
    "table": "flat",
    "group_by": [
     "assignee_names_canonical"
    ],
    "count_distinct": "doc_number"
   },
   {
    "kind": "sort",
    "table": "flat_by_assignee_names_canonical",
    "column": "doc_number_distinct",
    "ascending": false
   },
   {
    "kind": "export",
    "fmt": "csv",
    "tables": [
     "flat_by_assignee_names_canonical"
    ]
   }
  ]
 },
 {
