 {
  "name": "Remove self-transfers (assignor == assignee)",
  "load": {
   "limit": null
  },
  "steps": [
   {
    "kind": "normalize",
    "table": "flat",
    "column": "assignor_names",
    "scorer": "token_set"
   },
   {
    "kind": "normalize",
    "table": "flat",
    "column": "assignee_names",
    "scorer": "token_set"
   },
   {
    "kind": "compare",
    "table": "flat",
    "left": "assignor_names_canonical",
    "right": "assignee_names_canonical",
    "method": "exact",
    "action": "drop_matches"
   },
   {
    "kind": "export",
    "fmt": "parquet",
    "tables": [
