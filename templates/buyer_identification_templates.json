[
  {
    "name": "Buyers - firm-to-firm transactions (clean, enriched)",
    "load": { "limit": null },
    "steps": [
      { "kind": "filter", "table": "flat",
        "clauses": [
          { "column": "conveyance_text", "op": "contains", "value": "ASSIGNORS INTEREST", "value2": "", "case_sensitive": false },
          { "column": "assignee_names", "op": "not_empty", "value": "", "value2": "", "case_sensitive": false },
          { "column": "recorded_date", "op": "not_empty", "value": "", "value2": "", "case_sensitive": false }
        ],
        "combine": "and" },

      { "kind": "reference_match", "table": "flat", "column": "assignor_names",
        "reference_path": "reference/g_assignee_disambiguated.tsv",
        "name_column": "disambig_assignee_organization", "id_column": "assignee_id",
        "threshold": 90, "scorer": "token_set", "mode": "all", "action": "keep_matched" },

      { "kind": "classify", "table": "flat", "column": "assignee_names", "method": "rules", "mode": "all" },
      { "kind": "filter", "table": "flat",
        "clauses": [
          { "column": "assignee_names_type", "op": "equals", "value": "company", "value2": "", "case_sensitive": false },
          { "column": "assignee_names_type", "op": "equals", "value": "unknown", "value2": "", "case_sensitive": false }
        ],
        "combine": "or" },

      { "kind": "reference_match", "table": "flat", "column": "assignee_names",
        "reference_path": "reference/g_assignee_disambiguated.tsv",
        "name_column": "disambig_assignee_organization", "id_column": "assignee_id",
        "threshold": 90, "scorer": "token_set", "mode": "any", "action": "flag" },

      { "kind": "normalize", "table": "flat", "column": "assignor_names", "scorer": "token_set" },
      { "kind": "normalize", "table": "flat", "column": "assignee_names", "scorer": "token_set" },
      { "kind": "compare", "table": "flat",
        "left": "assignor_names_canonical", "right": "assignee_names_canonical",
        "method": "exact", "action": "drop_matches" },

      { "kind": "derive", "table": "flat", "source": "transaction_date", "op": "year" },

      { "kind": "export", "fmt": "parquet", "tables": ["flat"],
        "columns": { "flat": [
          "reel_no", "frame_no", "recorded_date", "execution_date", "transaction_date",
          "transaction_date_year", "date_source", "conveyance_text",
          "assignor_names", "assignor_names_canonical",
          "assignee_names", "assignee_names_canonical",
          "assignee_names_matched", "assignee_names_assignee_id",
          "invention_title", "doc_country", "doc_number", "doc_kind", "doc_date" ] },
        "renames": { "flat": {
          "transaction_date_year": "year",
          "assignee_names_canonical": "buyer_clean",
          "assignee_names_assignee_id": "buyer_id",
          "assignee_names_matched": "buyer_in_gazetteer",
          "assignor_names_canonical": "seller_clean" } } }
    ]
  },

